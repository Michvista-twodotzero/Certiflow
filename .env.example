# ================================
# CertiFlow - Environment Variables
# ================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-256-bits
JWT_EXPIRES_IN=7d

# API Gateway
GATEWAY_PORT=3000

# Compliance Service
COMPLIANCE_SERVICE_PORT=3001
COMPLIANCE_SERVICE_URL=http://localhost:3001

# AI Worker
AI_WORKER_PORT=3002
AI_WORKER_URL=http://localhost:3002

# Frontend
# On Railway, point this to the public API gateway URL, e.g. https://your-api-gateway.up.railway.app/api
PUBLIC_API_BASE_URL=http://localhost:3000/api

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/certiflow_compliance

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (Upstash)
REDIS_URL=redis://your-upstash-redis-url:6379

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FILE_SEARCH_STORE_NAME=
GEMINI_FILE_SEARCH_DISPLAY_NAME=certiflow-osha-reference

# OCR
OCR_PROVIDER=google-vision
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/google-service-account.json
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_CLOUD_QUOTA_PROJECT=

# Email notifications (Gmail SMTP or any SMTP server)
SMTP_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
